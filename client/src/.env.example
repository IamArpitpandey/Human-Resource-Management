# ===== HRMS Frontend Environment Variables =====
# Copy this file to `.env` and adjust values as needed.

# Backend API URL
# Examples:
#   VITE_API_URL=http://localhost:5000/api          (default)
#   VITE_API_URL=http://localhost:8000/api          (alt port)
#   VITE_API_URL=https://api.your-domain.com/api    (production)
VITE_API_URL=http://localhost:5000/api
